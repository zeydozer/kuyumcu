APP_NAME=Kuyumcu
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://bilezik.zeydozer.com
APP_PORT=8000
APP_DOMAIN=bilezik.zeydozer.com
APP_UPSTREAM=app:80
HTTP_PORT=80
HTTPS_PORT=443
CLIENT_MAX_BODY_SIZE=25m
NGINX_RELOAD_POLL_SECONDS=60
LETSENCRYPT_EMAIL=mail@example.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=kuyumcu
DB_USERNAME=kuyumcu
DB_PASSWORD=strong-db-password
MYSQL_ROOT_PASSWORD=strong-root-password
FORWARD_DB_PORT=3307

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=bilezik.zeydozer.com
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=bilezik.zeydozer.com

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@zeydozer.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

INIT_ADMIN_NAME=Serkan Demir
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=change-me-now
INIT_CUSTOMER_NAME=Zeynep Kaya
INIT_CUSTOMER_EMAIL=customer@example.com
INIT_CUSTOMER_PASSWORD=change-me-now
